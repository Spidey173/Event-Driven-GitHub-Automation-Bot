# Application Configuration
APP_NAME="GitHub Automation Bot"
APP_ENV=development  # development, staging, production
DEBUG=true

# Database Settings
# Use postgresql+asyncpg for SQLAlchemy async operations
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/github_bot"

# Security (Generate a strong secret key for session cookies)
# e.g., openssl rand -hex 32
SECRET_KEY="change_me_to_a_secure_random_string"
ENCRYPTION_KEY="change_me_to_32_urlsafe_base64_encoded_bytes="

# GitHub Integration
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"
GITHUB_WEBHOOK_SECRET="your_github_webhook_secret"
WEBHOOK_BASE_URL="http://localhost:8000"

# CORS Settings (JSON string list)
BACKEND_CORS_ORIGINS='["http://localhost:3000"]'

